#!/bin/sh
set -eu

DEV_ROOT=${SHADOW_DEV_ROOT:-/home/daviziks/dev}
CACHE_ROOT=${SHADOW_GIT_CACHE:-$DEV_ROOT/.cache/git}
PKG_CACHE_ROOT=${SHADOW_PKG_CACHE:-$DEV_ROOT/.cache/pkg}
TASK_META=.shadow

usage() {
  cat <<'USAGE'
Usage: shadow-task <command> [args]

Commands:
  new <task> [owner/repo[@base][=work]...]
      Create a task directory and clone repos using the shared bare cache.
  pick <task> [owner]
      Select repos with fzf from a GitHub owner/user, then create the task.
  list
      List task directories.
  path <task>
      Print a task directory path.
  shell <task>
      Open a shell in the task with task-local podman/docker wrappers first in PATH.
  env <task>
      Print shell exports for the task.
  podman <task> [args...]
      Run podman with task-local storage and runroot.
  docker <task> [args...]
      Docker-compatible alias for the task-local podman command.
  network <task>
      Ensure the task's private podman network exists.
  cache-update <owner/repo> [...]
      Create or refresh bare git mirrors.
  destroy <task>
      Remove task containers/storage and delete the task directory.

Repo spec format:
  owner/repo              clone the repo default branch
  owner/repo@develop      clone from develop
  owner/repo@main=fix-x   clone from main, then create/switch local branch fix-x
USAGE
}

fail() {
  printf '%s\n' "$*" >&2
  exit 1
}

need() {
  command -v "$1" >/dev/null 2>&1 || fail "missing required command: $1"
}

slug_ok() {
  case "$1" in
    ''|.*|*/*|*' '*|*[^A-Za-z0-9._-]*) return 1 ;;
    *) return 0 ;;
  esac
}

ensure_dev_root() {
  mkdir -p "$DEV_ROOT" "$CACHE_ROOT" "$PKG_CACHE_ROOT"
}

task_path() {
  slug_ok "$1" || fail "invalid task slug: $1"
  printf '%s/%s\n' "$DEV_ROOT" "$1"
}

ensure_task() {
  dir=$(task_path "$1")
  [ -d "$dir" ] || fail "task does not exist: $1"
  printf '%s\n' "$dir"
}

repo_owner() {
  printf '%s\n' "${1%%/*}"
}

repo_name() {
  name=${1#*/}
  printf '%s\n' "$name"
}

cache_path() {
  owner=$(repo_owner "$1")
  name=$(repo_name "$1")
  printf '%s/%s/%s.git\n' "$CACHE_ROOT" "$owner" "$name"
}

repo_default_branch() {
  gh repo view "$1" --json defaultBranchRef --jq '.defaultBranchRef.name' 2>/dev/null || printf '%s\n' main
}

repo_clone_url() {
  gh repo view "$1" --json url,sshUrl --jq '.url // .sshUrl' 2>/dev/null || printf 'https://github.com/%s.git
' "$1"
}

parse_spec() {
  spec=$1
  work_branch=
  base_branch=
  case "$spec" in
    *=*) work_branch=${spec#*=}; spec=${spec%%=*} ;;
  esac
  case "$spec" in
    *@*) base_branch=${spec#*@}; repo=${spec%@*} ;;
    *) repo=$spec ;;
  esac
  case "$repo" in
    */*) : ;;
    *) fail "repo must be owner/name: $repo" ;;
  esac
}

cache_update_one() {
  need git
  ensure_dev_root
  repo=$1
  cache=$(cache_path "$repo")
  url=$(repo_clone_url "$repo")
  mkdir -p "$(dirname "$cache")"
  if [ -d "$cache" ]; then
    git -C "$cache" remote set-url origin "$url"
    git -C "$cache" remote update --prune
  else
    git clone --mirror "$url" "$cache"
  fi
}

write_storage_conf() {
  task_dir=$1
  conf="$task_dir/$TASK_META/containers-storage.conf"
  mkdir -p "$task_dir/$TASK_META/podman/root" "$task_dir/$TASK_META/podman/run" "$task_dir/$TASK_META/bin"
  cat >"$conf" <<EOF
[storage]
driver = "overlay"
runroot = "$task_dir/$TASK_META/podman/run"
graphroot = "$task_dir/$TASK_META/podman/root"

[storage.options]
mount_program = "$(command -v fuse-overlayfs 2>/dev/null || printf fuse-overlayfs)"
EOF
}

script_path() {
  case "$0" in
    /*) printf '%s\n' "$0" ;;
    *) command -v "$0" 2>/dev/null || printf '%s/%s\n' "$(pwd)" "$0" ;;
  esac
}

write_wrappers() {
  slug=$1
  task_dir=$(ensure_task "$slug")
  write_storage_conf "$task_dir"
  self=$(script_path)
  mkdir -p "$task_dir/$TASK_META/bin"
  cat >"$task_dir/$TASK_META/bin/podman" <<EOF
#!/bin/sh
exec "$self" podman "$slug" "\$@"
EOF
  cat >"$task_dir/$TASK_META/bin/docker" <<EOF
#!/bin/sh
exec "$self" docker "$slug" "\$@"
EOF
  chmod +x "$task_dir/$TASK_META/bin/podman" "$task_dir/$TASK_META/bin/docker"
  cat >"$task_dir/.envrc" <<EOF
export SHADOW_TASK="$slug"
export SHADOW_TASK_DIR="$task_dir"
export BUN_INSTALL_CACHE_DIR="$PKG_CACHE_ROOT/bun"
export npm_config_cache="$PKG_CACHE_ROOT/npm"
export COREPACK_HOME="$PKG_CACHE_ROOT/corepack"
PATH_add "$task_dir/$TASK_META/bin"
EOF
}

record_repo() {
  task_dir=$1
  repo=$2
  base=$3
  work=$4
  name=$(repo_name "$repo")
  mkdir -p "$task_dir/$TASK_META"
  printf '%s\t%s\t%s\t%s\n' "$repo" "$name" "$base" "$work" >>"$task_dir/$TASK_META/repos.tsv"
}

clone_one() {
  slug=$1
  spec=$2
  task_dir=$(task_path "$slug")
  parse_spec "$spec"
  cache_update_one "$repo"
  name=$(repo_name "$repo")
  dst="$task_dir/$name"
  [ ! -e "$dst" ] || fail "destination already exists: $dst"
  if [ -z "$base_branch" ]; then
    base_branch=$(repo_default_branch "$repo")
  fi
  cache=$(cache_path "$repo")
  git clone --branch "$base_branch" "$cache" "$dst"
  git -C "$dst" remote set-url origin "$(repo_clone_url "$repo")"
  if [ -n "$work_branch" ] && [ "$work_branch" != "$base_branch" ]; then
    git -C "$dst" switch -c "$work_branch"
  fi
  record_repo "$task_dir" "$repo" "$base_branch" "$work_branch"
}

cmd_new() {
  [ $# -ge 1 ] || fail "new requires a task slug"
  slug=$1
  shift
  slug_ok "$slug" || fail "invalid task slug: $slug"
  ensure_dev_root
  task_dir=$(task_path "$slug")
  [ ! -e "$task_dir" ] || fail "task already exists: $task_dir"
  mkdir -p "$task_dir/$TASK_META"
  : >"$task_dir/$TASK_META/repos.tsv"
  cat >"$task_dir/$TASK_META/task.env" <<EOF
SHADOW_TASK=$slug
SHADOW_TASK_DIR=$task_dir
EOF
  if [ $# -eq 0 ]; then
    fail "new needs at least one repo spec; use pick for fzf selection"
  fi
  for spec in "$@"; do
    clone_one "$slug" "$spec"
  done
  write_wrappers "$slug"
  printf '%s\n' "$task_dir"
}

cmd_pick() {
  [ $# -ge 1 ] || fail "pick requires a task slug"
  slug=$1
  owner=${2:-}
  need gh
  need fzf
  if [ -z "$owner" ]; then
    owner=$(gh api user --jq .login)
  fi
  repos=$(gh repo list "$owner" --limit 300 --json nameWithOwner,defaultBranchRef --jq '.[] | .nameWithOwner + "\t" + .defaultBranchRef.name' | fzf -m --with-nth=1,2 | cut -f1)
  [ -n "$repos" ] || fail "no repos selected"
  # shellcheck disable=SC2086
  cmd_new "$slug" $repos
}

cmd_list() {
  ensure_dev_root
  find "$DEV_ROOT" -mindepth 1 -maxdepth 1 -type d ! -name '.*' -exec sh -c '[ -f "$1/.shadow/task.env" ] && basename "$1"' _ {} \; | sort
}

cmd_env() {
  slug=$1
  task_dir=$(ensure_task "$slug")
  write_wrappers "$slug"
  cat <<EOF
export SHADOW_TASK="$slug"
export SHADOW_TASK_DIR="$task_dir"
export PATH="$task_dir/$TASK_META/bin:\$PATH"
export BUN_INSTALL_CACHE_DIR="$PKG_CACHE_ROOT/bun"
export npm_config_cache="$PKG_CACHE_ROOT/npm"
export COREPACK_HOME="$PKG_CACHE_ROOT/corepack"
EOF
}

cmd_shell() {
  slug=$1
  task_dir=$(ensure_task "$slug")
  write_wrappers "$slug"
  cd "$task_dir"
  export SHADOW_TASK="$slug"
  export SHADOW_TASK_DIR="$task_dir"
  export PATH="$task_dir/$TASK_META/bin:$PATH"
  export BUN_INSTALL_CACHE_DIR="$PKG_CACHE_ROOT/bun"
  export npm_config_cache="$PKG_CACHE_ROOT/npm"
  export COREPACK_HOME="$PKG_CACHE_ROOT/corepack"
  exec "${SHELL:-sh}"
}

task_network_name() {
  printf '%s\n' "shadow-$1"
}

reject_host_exposure_args() {
  prev=
  for arg in "$@"; do
    if [ "$prev" = network ]; then
      fail "container network selection is managed by shadow-task; use task-network to inspect it"
    fi

    case "$arg" in
      -p|-P|--publish|--publish-all)
        fail "host port publishing is disabled for task containers; use the task gateway instead"
        ;;
      -p*|--publish=*)
        fail "host port publishing is disabled for task containers; use the task gateway instead"
        ;;
      --network=*|--net=*)
        fail "container network selection is managed by shadow-task; use task-network to inspect it"
        ;;
      --network|--net)
        prev=network
        ;;
    esac
  done
}

compose_file_has_ports() {
  files=
  prev=
  for arg in "$@"; do
    if [ "$prev" = file ]; then
      files="$files $arg"
      prev=
      continue
    fi
    case "$arg" in
      -f|--file)
        prev=file
        ;;
      -f*)
        files="$files ${arg#-f}"
        ;;
      --file=*)
        files="$files ${arg#--file=}"
        ;;
    esac
  done

  if [ -z "$files" ]; then
    files="compose.yml compose.yaml docker-compose.yml docker-compose.yaml"
  fi

  for file in $files; do
    [ -f "$file" ] || continue
    if grep -Eq '^[[:space:]]*ports:[[:space:]]*($|#)' "$file"; then
      return 0
    fi
  done
  return 1
}

ensure_podman_network() {
  task_dir=$1
  runroot=$2
  name=$3
  if podman --root "$task_dir/$TASK_META/podman/root" --runroot "$runroot" network inspect "$name" >/dev/null 2>&1; then
    return 0
  fi
  podman --root "$task_dir/$TASK_META/podman/root" --runroot "$runroot" network create "$name" >/dev/null
}

cmd_podman() {
  [ $# -ge 1 ] || fail "podman requires a task slug"
  slug=$1
  shift
  need podman
  task_dir=$(ensure_task "$slug")
  write_storage_conf "$task_dir"
  runtime_base=${XDG_RUNTIME_DIR:-/tmp}
  runroot="$runtime_base/shadow-tasks/$slug/podman-run"
  mkdir -p "$runroot"
  export CONTAINERS_STORAGE_CONF="$task_dir/$TASK_META/containers-storage.conf"

  reject_host_exposure_args "$@"

  if [ $# -gt 0 ]; then
    subcommand=$1
    shift
    network_name=$(task_network_name "$slug")
    case "$subcommand" in
      run|create)
        ensure_podman_network "$task_dir" "$runroot" "$network_name"
        exec podman --root "$task_dir/$TASK_META/podman/root" --runroot "$runroot" "$subcommand" --network "$network_name" "$@"
        ;;
      compose)
        if compose_file_has_ports "$@"; then
          fail "compose files with ports: are disabled for task containers; route through the task gateway instead"
        fi
        ;;
    esac
    set -- "$subcommand" "$@"
  fi

  exec podman --root "$task_dir/$TASK_META/podman/root" --runroot "$runroot" "$@"
}

cmd_network() {
  [ $# -eq 1 ] || fail "network requires a task slug"
  slug=$1
  task_dir=$(ensure_task "$slug")
  write_storage_conf "$task_dir"
  runtime_base=${XDG_RUNTIME_DIR:-/tmp}
  runroot="$runtime_base/shadow-tasks/$slug/podman-run"
  mkdir -p "$runroot"
  name=$(task_network_name "$slug")
  ensure_podman_network "$task_dir" "$runroot" "$name"
  printf '%s\n' "$name"
}

cmd_destroy() {
  [ $# -eq 1 ] || fail "destroy requires a task slug"
  slug=$1
  task_dir=$(ensure_task "$slug")
  case "$task_dir" in
    "$DEV_ROOT"/*) : ;;
    *) fail "refusing to delete outside DEV_ROOT: $task_dir" ;;
  esac
  if command -v podman >/dev/null 2>&1; then
    "$0" podman "$slug" system reset --force >/dev/null 2>&1 || true
  fi
  rm -rf "$task_dir"
}

cmd=${1:-}
case "$cmd" in
  new) shift; cmd_new "$@" ;;
  pick) shift; cmd_pick "$@" ;;
  list) shift; cmd_list "$@" ;;
  path) shift; [ $# -eq 1 ] || fail "path requires a task slug"; task_path "$1" ;;
  shell|enter) shift; [ $# -eq 1 ] || fail "$cmd requires a task slug"; cmd_shell "$1" ;;
  env) shift; [ $# -eq 1 ] || fail "env requires a task slug"; cmd_env "$1" ;;
  podman) shift; cmd_podman "$@" ;;
  docker) shift; cmd_podman "$@" ;;
  network) shift; cmd_network "$@" ;;
  cache-update) shift; [ $# -ge 1 ] || fail "cache-update requires repo specs"; for repo in "$@"; do cache_update_one "$repo"; done ;;
  destroy|rm|delete) shift; cmd_destroy "$@" ;;
  -h|--help|help|'') usage ;;
  *) usage >&2; exit 2 ;;
esac
