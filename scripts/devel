#!/bin/sh
set -eu

DEV_ROOT=${SHADOW_DEV_ROOT:-/home/daviziks/dev}
CACHE_ROOT=${SHADOW_GIT_CACHE:-$DEV_ROOT/.cache/git}
PKG_CACHE_ROOT=${SHADOW_PKG_CACHE:-$DEV_ROOT/.cache/pkg}
STORE_FILE=${SHADOW_REPO_STORE:-$DEV_ROOT/.devel/repos.tsv}
TASK_META=.devel
PROFILE_ROOT=${SHADOW_SERVICE_PROFILE_ROOT:-/etc/shadow/service-profiles}
CODER_TOKEN_FILE=${SHADOW_CODER_TOKEN_FILE:-$DEV_ROOT/.services/coder/admin-session-token}

usage() {
  cat <<'USAGE'
Usage: devel <command> [args]

Workflow:
  devel store add owner/repo [owner/repo...]
  devel create <task-slug>
  devel coder create <workspace> [--profile profile] [owner/repo[@base][=work]...]
  cd $(devel path <task-slug>)
  devel enter <task-slug>

Commands:
  store [add|rm|list|clear] [owner/repo[@base][=work]...]
      Maintain the repo catalog used by create. With repo args, store adds them.
  create <task> [owner/repo[@base][=work]...]
      Create a task. Without repo args, select repos dynamically from the store.
  list
      List task directories.
  path <task>
      Print a task path.
  enter <task>
      Open a shell in the task with task-local container isolation active.
  env <task>
      Print shell exports for a task.
  destroy <task>
      Delete one task and its task-local container state.
  prune
      Delete every task and every task-local container state.
  cache update [owner/repo...]
      Refresh shared bare git caches. Defaults to all stored repos.
  profile [list|show|copy] [profile] [task]
      Inspect or copy service profile compose files.
  coder create <workspace> [--profile profile] [owner/repo[@base][=work]...]
      Create a Coder workspace from the fullstack-task template.

Repo spec format:
  owner/repo              clone the repo default branch
  owner/repo@develop      clone from develop
  owner/repo@main=fix-x   clone from main, then create/switch local branch fix-x
USAGE
}

fail() { printf '%s\n' "$*" >&2; exit 1; }
need() { command -v "$1" >/dev/null 2>&1 || fail "missing required command: $1"; }

slug_ok() {
  case "$1" in
    ''|.*|*/*|*' '*|*[^A-Za-z0-9._-]*) return 1 ;;
    *) return 0 ;;
  esac
}

ensure_dev_root() {
  mkdir -p "$DEV_ROOT" "$CACHE_ROOT" "$PKG_CACHE_ROOT" "$(dirname "$STORE_FILE")"
  [ -f "$STORE_FILE" ] || : >"$STORE_FILE"
}

task_path() {
  slug_ok "$1" || fail "invalid task slug: $1"
  printf '%s/%s\n' "$DEV_ROOT" "$1"
}

ensure_task() {
  dir=$(task_path "$1")
  [ -d "$dir" ] || fail "task does not exist: $1"
  printf '%s\n' "$dir"
}

repo_owner() { printf '%s\n' "${1%%/*}"; }
repo_name() { name=${1#*/}; name=${name%%@*}; name=${name%%=*}; printf '%s\n' "$name"; }

repo_from_spec() {
  spec=$1
  spec=${spec%%=*}
  spec=${spec%%@*}
  printf '%s\n' "$spec"
}

valid_repo_spec() {
  repo=$(repo_from_spec "$1")
  case "$repo" in
    */*) return 0 ;;
    *) return 1 ;;
  esac
}

cache_path() {
  repo=$(repo_from_spec "$1")
  owner=$(repo_owner "$repo")
  name=$(repo_name "$repo")
  printf '%s/%s/%s.git\n' "$CACHE_ROOT" "$owner" "$name"
}

repo_default_branch() {
  gh repo view "$1" --json defaultBranchRef --jq '.defaultBranchRef.name' 2>/dev/null || printf '%s\n' main
}

repo_clone_url() {
  gh repo view "$1" --json url,sshUrl --jq '.url // .sshUrl' 2>/dev/null || printf 'https://github.com/%s.git\n' "$1"
}

parse_spec() {
  spec=$1
  work_branch=
  base_branch=
  case "$spec" in *=*) work_branch=${spec#*=}; spec=${spec%%=*} ;; esac
  case "$spec" in *@*) base_branch=${spec#*@}; repo=${spec%@*} ;; *) repo=$spec ;; esac
  case "$repo" in */*) : ;; *) fail "repo must be owner/name: $repo" ;; esac
}

store_normalize_line() {
  spec=$1
  valid_repo_spec "$spec" || fail "repo must be owner/name: $spec"
  repo=$(repo_from_spec "$spec")
  printf '%s\t%s\n' "$repo" "$spec"
}

cmd_store() {
  ensure_dev_root
  sub=${1:-list}
  case "$sub" in
    add)
      shift
      [ $# -ge 1 ] || fail "store add requires repo specs"
      tmp=$(mktemp)
      awk -F '\t' 'NF >= 2 { print $1 "\t" $2 }' "$STORE_FILE" >"$tmp"
      for spec in "$@"; do store_normalize_line "$spec" >>"$tmp"; done
      awk -F '\t' '!seen[$1]++ { print $1 "\t" $2 }' "$tmp" | sort >"$STORE_FILE"
      rm -f "$tmp"
      ;;
    rm|remove|delete)
      shift
      [ $# -ge 1 ] || fail "store rm requires owner/repo names"
      tmp=$(mktemp)
      cp "$STORE_FILE" "$tmp"
      for spec in "$@"; do
        repo=$(repo_from_spec "$spec")
        awk -F '\t' -v repo="$repo" '$1 != repo { print $1 "\t" $2 }' "$tmp" >"$tmp.next"
        mv "$tmp.next" "$tmp"
      done
      mv "$tmp" "$STORE_FILE"
      ;;
    clear)
      : >"$STORE_FILE"
      ;;
    list|ls)
      awk -F '\t' 'NF >= 2 { print $2 }' "$STORE_FILE"
      ;;
    *)
      # Convenience: devel store owner/repo owner/repo2
      cmd_store add "$@"
      ;;
  esac
}

select_stored_repos() {
  ensure_dev_root
  need fzf
  [ -s "$STORE_FILE" ] || fail "repo store is empty; add repos with: devel store add owner/repo"
  awk -F '\t' 'NF >= 2 { print $2 }' "$STORE_FILE" | fzf -m --prompt='repos> '
}

cache_update_one() {
  need git
  ensure_dev_root
  spec=$1
  repo=$(repo_from_spec "$spec")
  cache=$(cache_path "$repo")
  url=$(repo_clone_url "$repo")
  mkdir -p "$(dirname "$cache")"
  if [ -d "$cache" ]; then
    git -C "$cache" remote set-url origin "$url"
    git -C "$cache" remote update --prune
  else
    git clone --mirror "$url" "$cache"
  fi
}

write_storage_conf() {
  task_dir=$1
  conf="$task_dir/$TASK_META/containers-storage.conf"
  mkdir -p "$task_dir/$TASK_META/podman/root" "$task_dir/$TASK_META/podman/run" "$task_dir/$TASK_META/bin"
  cat >"$conf" <<CONF
[storage]
driver = "overlay"
runroot = "$task_dir/$TASK_META/podman/run"
graphroot = "$task_dir/$TASK_META/podman/root"

[storage.options]
mount_program = "$(command -v fuse-overlayfs 2>/dev/null || printf fuse-overlayfs)"
CONF
}

script_path() {
  case "$0" in /*) printf '%s\n' "$0" ;; *) command -v "$0" 2>/dev/null || printf '%s/%s\n' "$(pwd)" "$0" ;; esac
}

write_wrappers() {
  slug=$1
  task_dir=$(ensure_task "$slug")
  write_storage_conf "$task_dir"
  self=$(script_path)
  mkdir -p "$task_dir/$TASK_META/bin"
  cat >"$task_dir/$TASK_META/bin/podman" <<WRAP
#!/bin/sh
exec "$self" __podman "$slug" "\$@"
WRAP
  cat >"$task_dir/$TASK_META/bin/docker" <<WRAP
#!/bin/sh
exec "$self" __docker "$slug" "\$@"
WRAP
  chmod +x "$task_dir/$TASK_META/bin/podman" "$task_dir/$TASK_META/bin/docker"
  cat >"$task_dir/.envrc" <<ENVRC
export DEVEL_TASK="$slug"
export DEVEL_TASK_DIR="$task_dir"
export BUN_INSTALL_CACHE_DIR="$PKG_CACHE_ROOT/bun"
export npm_config_cache="$PKG_CACHE_ROOT/npm"
export COREPACK_HOME="$PKG_CACHE_ROOT/corepack"
PATH_add "$task_dir/$TASK_META/bin"
ENVRC
}

record_repo() {
  task_dir=$1; repo=$2; base=$3; work=$4
  name=$(repo_name "$repo")
  mkdir -p "$task_dir/$TASK_META"
  printf '%s\t%s\t%s\t%s\n' "$repo" "$name" "$base" "$work" >>"$task_dir/$TASK_META/repos.tsv"
}

clone_one() {
  slug=$1; spec=$2
  task_dir=$(task_path "$slug")
  parse_spec "$spec"
  cache_update_one "$repo"
  name=$(repo_name "$repo")
  dst="$task_dir/$name"
  [ ! -e "$dst" ] || fail "destination already exists: $dst"
  if [ -z "$base_branch" ]; then base_branch=$(repo_default_branch "$repo"); fi
  cache=$(cache_path "$repo")
  git clone --branch "$base_branch" "$cache" "$dst"
  git -C "$dst" remote set-url origin "$(repo_clone_url "$repo")"
  if [ -n "$work_branch" ] && [ "$work_branch" != "$base_branch" ]; then
    git -C "$dst" switch -c "$work_branch"
  fi
  record_repo "$task_dir" "$repo" "$base_branch" "$work_branch"
}

cmd_create() {
  [ $# -ge 1 ] || fail "create requires a task slug"
  slug=$1; shift
  slug_ok "$slug" || fail "invalid task slug: $slug"
  ensure_dev_root
  task_dir=$(task_path "$slug")
  [ ! -e "$task_dir" ] || fail "task already exists: $task_dir"
  if [ $# -eq 0 ]; then
    selected=$(select_stored_repos) || fail "no repos selected"
    set -- $selected
  fi
  [ $# -ge 1 ] || fail "create needs at least one repo"
  mkdir -p "$task_dir/$TASK_META"
  : >"$task_dir/$TASK_META/repos.tsv"
  cat >"$task_dir/$TASK_META/task.env" <<TASKENV
DEVEL_TASK=$slug
DEVEL_TASK_DIR=$task_dir
TASKENV
  for spec in "$@"; do clone_one "$slug" "$spec"; done
  write_wrappers "$slug"
  printf '%s\n' "$task_dir"
}

cmd_list() {
  ensure_dev_root
  find "$DEV_ROOT" -mindepth 1 -maxdepth 1 -type d ! -name '.*' -exec sh -c '[ -f "$1/.devel/task.env" ] && basename "$1"' _ {} \; | sort
}

cmd_env() {
  [ $# -eq 1 ] || fail "env requires a task slug"
  slug=$1
  task_dir=$(ensure_task "$slug")
  write_wrappers "$slug"
  cat <<ENV
export DEVEL_TASK="$slug"
export DEVEL_TASK_DIR="$task_dir"
export SHADOW_TASK="$slug"
export SHADOW_TASK_DIR="$task_dir"
export PATH="$task_dir/$TASK_META/bin:\$PATH"
export BUN_INSTALL_CACHE_DIR="$PKG_CACHE_ROOT/bun"
export npm_config_cache="$PKG_CACHE_ROOT/npm"
export COREPACK_HOME="$PKG_CACHE_ROOT/corepack"
ENV
}

cmd_enter() {
  [ $# -eq 1 ] || fail "enter requires a task slug"
  slug=$1
  task_dir=$(ensure_task "$slug")
  write_wrappers "$slug"
  cd "$task_dir"
  export DEVEL_TASK="$slug" DEVEL_TASK_DIR="$task_dir" SHADOW_TASK="$slug" SHADOW_TASK_DIR="$task_dir"
  export PATH="$task_dir/$TASK_META/bin:$PATH"
  export BUN_INSTALL_CACHE_DIR="$PKG_CACHE_ROOT/bun" npm_config_cache="$PKG_CACHE_ROOT/npm" COREPACK_HOME="$PKG_CACHE_ROOT/corepack"
  exec "${SHELL:-sh}"
}

task_network_name() { printf '%s\n' "devel-$1"; }

reject_host_exposure_args() {
  prev=
  for arg in "$@"; do
    if [ "$prev" = network ]; then fail "container network selection is managed by devel"; fi
    case "$arg" in
      -p|-P|--publish|--publish-all|-p*|--publish=*) fail "host port publishing is disabled inside devel tasks" ;;
      --network=*|--net=*) fail "container network selection is managed by devel" ;;
      --network|--net) prev=network ;;
    esac
  done
}

compose_file_has_ports() {
  files=; prev=
  for arg in "$@"; do
    if [ "$prev" = file ]; then files="$files $arg"; prev=; continue; fi
    case "$arg" in -f|--file) prev=file ;; -f*) files="$files ${arg#-f}" ;; --file=*) files="$files ${arg#--file=}" ;; esac
  done
  [ -n "$files" ] || files="compose.yml compose.yaml docker-compose.yml docker-compose.yaml"
  for file in $files; do
    [ -f "$file" ] || continue
    grep -Eq '^[[:space:]]*ports:[[:space:]]*($|#)' "$file" && return 0
  done
  return 1
}

ensure_podman_network() {
  task_dir=$1; runroot=$2; name=$3
  if "$REAL_PODMAN" --root "$task_dir/$TASK_META/podman/root" --runroot "$runroot" network inspect "$name" >/dev/null 2>&1; then return 0; fi
  "$REAL_PODMAN" --root "$task_dir/$TASK_META/podman/root" --runroot "$runroot" network create "$name" >/dev/null
}

cmd_podman() {
  [ $# -ge 1 ] || fail "internal podman requires a task slug"
  slug=$1; shift
  need podman
  task_dir=$(ensure_task "$slug")
  REAL_PODMAN=${DEVEL_REAL_PODMAN:-/run/current-system/sw/bin/podman}
  [ -x "$REAL_PODMAN" ] || REAL_PODMAN=$(command -v podman)
  case "$REAL_PODMAN" in "$task_dir"/*) REAL_PODMAN=/run/current-system/sw/bin/podman ;; esac
  write_storage_conf "$task_dir"
  runtime_base=${XDG_RUNTIME_DIR:-/tmp}
  runroot="$runtime_base/devel-tasks/$slug/podman-run"
  mkdir -p "$runroot"
  export CONTAINERS_STORAGE_CONF="$task_dir/$TASK_META/containers-storage.conf"
  reject_host_exposure_args "$@"
  if [ $# -gt 0 ]; then
    subcommand=$1; shift
    network_name=$(task_network_name "$slug")
    case "$subcommand" in
      run|create)
        ensure_podman_network "$task_dir" "$runroot" "$network_name"
        exec "$REAL_PODMAN" --root "$task_dir/$TASK_META/podman/root" --runroot "$runroot" "$subcommand" --network "$network_name" "$@"
        ;;
      compose)
        compose_file_has_ports "$@" && fail "compose files with ports: are disabled inside devel tasks"
        ;;
    esac
    set -- "$subcommand" "$@"
  fi
  exec "$REAL_PODMAN" --root "$task_dir/$TASK_META/podman/root" --runroot "$runroot" "$@"
}

reset_task_containers() {
  slug=$1
  task_dir=$(ensure_task "$slug")
  if command -v podman >/dev/null 2>&1; then
    "$0" __podman "$slug" system reset --force >/dev/null 2>&1 || true
  fi
  rm -rf "$task_dir/$TASK_META/podman" "${XDG_RUNTIME_DIR:-/tmp}/devel-tasks/$slug" "${XDG_RUNTIME_DIR:-/tmp}/shadow-tasks/$slug"
}

cmd_destroy() {
  [ $# -eq 1 ] || fail "destroy requires a task slug"
  slug=$1
  task_dir=$(ensure_task "$slug")
  case "$task_dir" in "$DEV_ROOT"/*) : ;; *) fail "refusing to delete outside DEV_ROOT: $task_dir" ;; esac
  reset_task_containers "$slug"
  rm -rf "$task_dir"
}

cmd_prune() {
  ensure_dev_root
  for slug in $(cmd_list); do cmd_destroy "$slug"; done
}

cmd_cache() {
  ensure_dev_root
  sub=${1:-update}
  case "$sub" in
    update|refresh)
      shift || true
      if [ $# -eq 0 ]; then set -- $(awk -F '\t' 'NF >= 2 { print $2 }' "$STORE_FILE"); fi
      [ $# -ge 1 ] || fail "no repos to cache; add repos with devel store add"
      for repo in "$@"; do cache_update_one "$repo"; done
      ;;
    *) fail "unknown cache command: $sub" ;;
  esac
}

profile_path() {
  profile=$1
  case "$profile" in ''|.*|*/*|*[^A-Za-z0-9._-]*) fail "invalid profile: $profile" ;; esac
  printf '%s/%s.compose.yaml\n' "$PROFILE_ROOT" "$profile"
}

cmd_profile() {
  sub=${1:-list}
  case "$sub" in
    list|ls)
      [ -d "$PROFILE_ROOT" ] || fail "service profile root not found: $PROFILE_ROOT"
      find "$PROFILE_ROOT" -maxdepth 1 -type f -name '*.compose.yaml' -exec basename {} .compose.yaml \; | sort
      ;;
    show|cat)
      shift
      [ $# -eq 1 ] || fail "profile show requires a profile"
      file=$(profile_path "$1")
      [ -f "$file" ] || fail "unknown profile: $1"
      cat "$file"
      ;;
    copy)
      shift
      [ $# -ge 1 ] || fail "profile copy requires a profile"
      profile=$1; shift
      task=${1:-${DEVEL_TASK:-}}
      [ -n "$task" ] || fail "profile copy requires a task or DEVEL_TASK"
      task_dir=$(ensure_task "$task")
      file=$(profile_path "$profile")
      [ -f "$file" ] || fail "unknown profile: $profile"
      cp "$file" "$task_dir/compose.$profile.yaml"
      printf '%s\n' "$task_dir/compose.$profile.yaml"
      ;;
    *) fail "unknown profile command: $sub" ;;
  esac
}

coder_env() {
  export CODER_URL=${CODER_URL:-http://127.0.0.1:7080}
  if [ -z "${CODER_SESSION_TOKEN:-}" ] && [ -r "$CODER_TOKEN_FILE" ]; then
    CODER_SESSION_TOKEN=$(cat "$CODER_TOKEN_FILE")
    export CODER_SESSION_TOKEN
  fi
}

cmd_coder() {
  sub=${1:-}
  case "$sub" in
    create|new)
      shift
      [ $# -ge 1 ] || fail "coder create requires a workspace name"
      workspace=$1; shift
      profile=none
      repos=
      while [ $# -gt 0 ]; do
        case "$1" in
          --profile)
            shift
            [ $# -gt 0 ] || fail "--profile requires a value"
            profile=$1
            ;;
          --profile=*) profile=${1#--profile=} ;;
          *) repos="${repos}${repos:+ }$1" ;;
        esac
        shift
      done
      coder_env
      need coder
      exec coder create "$workspace" \
        --template fullstack-task \
        --parameter "repo_specs=$repos" \
        --parameter "service_profile=$profile" \
        --yes
      ;;
    open|url)
      shift
      coder_env
      need coder
      [ $# -eq 1 ] || fail "coder open requires a workspace name"
      coder show "$1" | sed -n '1,120p'
      ;;
    *) fail "unknown coder command: ${sub:-}" ;;
  esac
}

cmd=${1:-}
case "$cmd" in
  store) shift; cmd_store "$@" ;;
  create|new) shift; cmd_create "$@" ;;
  list|ls) shift; cmd_list "$@" ;;
  path) shift; [ $# -eq 1 ] || fail "path requires a task slug"; task_path "$1" ;;
  enter|shell) shift; cmd_enter "$@" ;;
  env) shift; cmd_env "$@" ;;
  destroy|rm|delete) shift; cmd_destroy "$@" ;;
  prune) shift; [ $# -eq 0 ] || fail "prune takes no args"; cmd_prune ;;
  cache) shift; cmd_cache "$@" ;;
  profile|profiles) shift; cmd_profile "$@" ;;
  coder) shift; cmd_coder "$@" ;;
  __podman|__docker) shift; cmd_podman "$@" ;;
  -h|--help|help|'') usage ;;
  *) usage >&2; exit 2 ;;
esac
